{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quasar-tool.local/schemas/screen.schema.json",
  "title": "Quasar Tool Screen Definition",
  "type": "object",
  "required": ["id", "name", "components"],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "route": {
      "type": "string"
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "props": {
          "type": "object"
        },
        "events": {
          "type": "object"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/component"
          }
        }
      }
    }
  }
}

